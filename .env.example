# Google Maps JavaScript API key (Places + Directions + Maps JavaScript API enabled).
# Without a key the site still works: booking inputs become plain text fields
# and the confirmation step shows a summary card instead of a live map.
VITE_GOOGLE_MAPS_API_KEY=

# Where booking/contact submissions are delivered (via https://formsubmit.co — no backend needed).
# First submission triggers a one-time activation email from FormSubmit.
VITE_BOOKING_EMAIL=bookings@styltaxi.example

# Public contact details shown on the site
VITE_PHONE=+34600000000
VITE_WHATSAPP=34600000000
